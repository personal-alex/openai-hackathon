# Server-side LLM classification gateway. Never use NEXT_PUBLIC_ names for these values.
LLM_PROVIDER=ollama
# Optional provider-agnostic override. Otherwise the selected provider's classifier model is used.
LLM_MODEL=
LLM_TIMEOUT_MS=10000
LLM_MAX_INPUT_CHARS=2000
LLM_MAX_OUTPUT_TOKENS=300
LLM_MAX_RETRIES=1
LLM_SESSION_CLASSIFICATION_CAP=3
LLM_SESSION_TOTAL_CAP=5

# Local-only Ollama. Do not configure Ollama values on Vercel.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_CLASSIFIER_MODEL=qwen3.5:9b

# Production OpenAI classifier. Leave the key empty locally unless intentionally testing it.
OPENAI_API_KEY=
OPENAI_CLASSIFIER_MODEL=gpt-5.6

# Optional transient-failure fallback. Leave blank unless enabled deliberately.
GEMINI_API_KEY=
GEMINI_CLASSIFIER_MODEL=gemini-2.5-flash
LLM_FALLBACK_PROVIDER=
# Deployment-only trusted proxy header name. Leave blank locally.
LIFE_NAVIGATOR_TRUSTED_IP_HEADER=
# Deployment-only shared guard endpoint and bearer token. Leave blank locally.
AI_SHARED_GUARD_URL=
AI_SHARED_GUARD_TOKEN=

# Local bootstrap mode; not a secret.
NEXT_PUBLIC_APP_MODE=development
