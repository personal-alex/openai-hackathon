# Server-side only. Leave empty until a reviewed pack registry and deployment secret are available.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6
# Deployment-only trusted proxy header name. Leave blank locally.
LIFE_NAVIGATOR_TRUSTED_IP_HEADER=
# Deployment-only shared guard endpoint and bearer token. Leave blank locally.
AI_SHARED_GUARD_URL=
AI_SHARED_GUARD_TOKEN=

# Local bootstrap mode; not a secret.
NEXT_PUBLIC_APP_MODE=development
